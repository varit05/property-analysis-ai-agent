# Environment
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Development — Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# Production — OpenAI (primary)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Production fallback — Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepAgent settings
SKILLS_DIR=server/api/properties/skills
MAX_AGENT_ITERATIONS=3